{
  "name": "retail-pos",
  "version": "1.0.0",
  "private": true,
  "description": "RetailPOS — Point of Sale System",
  "main": "electron/main.js",
  "scripts": {
    "install:all": "npm install --prefix backend && npm install --prefix frontend && npm install --prefix license-server",
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev": "npm-run-all --parallel dev:backend dev:frontend",
    "build:backend": "npm run build --prefix backend",
    "build:frontend": "npm run build --prefix frontend",
    "build:all": "npm-run-all build:backend build:frontend",
    "electron:dev": "npm run build:all && electron .",
    "electron:build": "npm run build:all && electron-builder --win",
    "electron:build:all": "npm run build:all && electron-builder --win --mac --linux",
    "license-server:setup": "npm run setup --prefix license-server",
    "license-server:dev": "npm run dev --prefix license-server",
    "license-server:build": "npm run build --prefix license-server",
    "license-server:start": "npm run start --prefix license-server"
  },
  "dependencies": {
    "embedded-postgres": "18.3.0-beta.17"
  },
  "devDependencies": {
    "electron": "^31.0.2",
    "electron-builder": "^24.13.3",
    "javascript-obfuscator": "^5.4.2",
    "jimp": "^1.6.1",
    "npm-run-all": "^4.1.5",
    "png2icons": "^2.0.1",
    "sharp": "^0.34.5"
  }
}
