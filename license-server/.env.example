NODE_ENV=production
PORT=3001

# ── Ed25519 Keys (base64-encoded PEM) ─────────────────────────────────────────
# Generate with: npm run setup
# Copy values from license-server/keys/env-values.txt
ED25519_PRIVATE_KEY=your_base64_encoded_private_key_here
ED25519_PUBLIC_KEY=your_base64_encoded_public_key_here

# ── SQLite database path ───────────────────────────────────────────────────────
# On Railway: mount a Volume at /data and set this to /data/licenses.db
# Locally: leave as default (./data/licenses.db)
DB_PATH=/data/licenses.db

# ── Admin credentials ──────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_strong_password

# ── JWT (for admin dashboard sessions) ────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret
