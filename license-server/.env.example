# License Server Configuration
# Copy this file to .env and fill in your values

PORT=3001

# Admin credentials (used to log in to the admin UI)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_to_a_strong_password

# JWT secret for admin sessions (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=replace_with_long_random_string

# Ed25519 Private Key for signing activation tokens (generated by: npm run setup)
# Paste the private key content here (base64 encoded)
ED25519_PRIVATE_KEY=

# Ed25519 Public Key (embed this in your Electron app's electron/license.js)
ED25519_PUBLIC_KEY=

# SQLite database file path
DB_PATH=./data/licenses.db

# Server public URL (used for CORS and display purposes)
SERVER_URL=http://localhost:3001
