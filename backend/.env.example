NODE_ENV=production
PORT=5000

# ── Database ───────────────────────────────────────────────────────────────────
# On Railway: add a PostgreSQL service and DATABASE_URL is injected automatically.
# For local dev: fill in the individual vars below instead.
DATABASE_URL=postgresql://user:password@host:5432/database

# Local dev (used only when DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=retail_pos
DB_USER=postgres
DB_PASSWORD=yourpassword

# ── Auth ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=8h

# ── CORS (optional) ────────────────────────────────────────────────────────────
# Only set when the frontend lives on a different domain than the backend.
# Leave unset when both are served from the same Railway service.
# FRONTEND_URL=https://your-app.up.railway.app
